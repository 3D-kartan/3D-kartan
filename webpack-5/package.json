{
  "name": "3d-kartan",
  "version": "1.0.0",
  "description": "A 3D map application, aimed to display 3D data in an easy to understand way. This application is built with Webpack-5 and uses Cesium JS in the background to display the globe and its content. Cesium JS is developed under the Apache-2.0 license and no modifications has been done to the core of Cesium JS.",
  "license": "Apache-2.0",
  "private": true,
  "author": {
    "name": "Albin Näslund",
    "url": "https://github.com/avalna"
  },
  "keywords": [
    "cesium",
    "CesiumJS",
    "webpack",
    "3D-kartan"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/3D-kartan"
  },
  "main": "index.js",
  "scripts": {
    "build": "webpack --mode production --config webpack.config.js",
    "start": "webpack serve --mode development --config webpack.config.js --port 4000",
    "start:built": "npx http-server -a localhost -p 4000 dist/"
  },
  "dependencies": {
    "@formio/js": "^5.3.1",
    "bootstrap": "^5.3.8",
    "cesium": "^1.141.0",
    "chart.js": "^4.5.1",
    "proj4": "^2.19.10"
  },
  "devDependencies": {
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^6.8.1",
    "html-webpack-plugin": "^5.6.0",
    "postcss-loader": "^8.2.1",
    "postcss-prefix-selector": "^2.1.1",
    "style-loader": "^3.3.3",
    "webpack": "^5.107.1",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.4"
  }
}
